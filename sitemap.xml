---
sitemap:
priority: 0.7
changefreq: weekly
lastmod: 2013-07-27T12:49:30-05:00
---
<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="sitemap.xsl"?>
<urlset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd" xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"> 
	<url>
		<loc>http://soranoiseki.com/</loc>
		<lastmod>2014-02-01T00:00:00+01:00</lastmod>
		<changefreq>weekly</changefreq>
		<priority>1.0</priority>
	</url>
	<url>
		<loc>http://soranoiseki.com/about.html</loc>
		<lastmod>2014-02-03T00:00:00+01:00</lastmod>
		<changefreq>never</changefreq>
		<priority>1.0</priority>
	</url>
	<url>
		<loc>http://soranoiseki.com/archive.html</loc>
		<lastmod>2014-02-01T00:00:00+01:00</lastmod>
		<changefreq>weekly</changefreq>
		<priority>1.0</priority>
	</url>
	{% for category in site.categories %}
	<url>
		<loc>http://soranoiseki.com/topic/{{ category | first | downcase }}/</loc>
		<lastmod>2014-02-01T00:00:00+01:00</lastmod>
		<changefreq>weekly</changefreq>
		<priority>1.0</priority>
	</url>
	{% endfor %}	
	{% for post in site.posts %}
	<url>
		<loc>http://soranoiseki.com{{ post.url }}/</loc>
		{% if post.lastmod == null %}
		<lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
		{% else %}
		<lastmod>{{ post.lastmod | date_to_xmlschema }}</lastmod>
		{% endif %}
		<changefreq>never</changefreq>
		<priority>1.0</priority>
	</url>
	{% endfor %}
	{% for page in site.pages %}
	{% if page.sitemap != null and page.sitemap != empty %}
	<url>
		<loc>http://soranoiseki.com{{ page.url }}</loc>
		<lastmod>{{ page.sitemap.lastmod | date_to_xmlschema }}</lastmod>
		<changefreq>{{ page.sitemap.changefreq }}</changefreq>
		<priority>{{ page.sitemap.priority }}</priority>
	</url>
	{% endif %}
	{% endfor %} </urlset>
